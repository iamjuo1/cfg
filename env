#!/bin/sh

umask 0077

alias ll='ls -hl'
alias la='ls -hla'
alias du='du -h'
alias df='df -h'
alias bb='cd .. && ls'
alias zathura='zathura --mode fullscreen'
alias src='doas nvim /etc/apk/repositories'

alias add='doas apk add'
alias del='doas apk del'

alias suspend='echo mem | doas tee /sys/power/state'
alias reboot='doas reboot'
alias poweroff='doas poweroff'

alias ga='git commit --amend'
alias gb='git branch'
alias gc='git checkout'
alias gd='git diff'
alias gg='git add . && git commit'
alias gp='git push'

alias v=nvim
alias k=kubectl

alias ms='mbsync -a && notmuch new'
alias mr='neomutt -F ~/.config/*/iamjuo.com'
alias mr2='mkdir -p /tmp/mail && mbsync -c ~/*/isyncrc -a && neomutt -F ~/.config/*/tmp.com'

alias bt='transmission-daemon -p 1337'

PS1=$(printf '\e[1m\e[91m$\e[92m $(git branch --show-current 2> /dev/null | sed "s/.*/& /")\e[0m\e[4 q')
